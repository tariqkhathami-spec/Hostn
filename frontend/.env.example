# MongoDB Connection String (REQUIRED)
# Example: mongodb+srv://username:password@cluster.mongodb.net/hostn?retryWrites=true&w=majority
MONGODB_URI=

# JWT Secret Key for signing authentication tokens (REQUIRED)
# WARNING: Use a strong random secret in production. Never use default values.
# Generate with: openssl rand -base64 32
# Minimum 32 characters recommended
JWT_SECRET=

# JWT Token Expiration Time (Optional, default: 7d)
# Format: number + unit (d=days, h=hours, m=minutes, s=seconds)
# Examples: 7d, 24h, 60m
JWT_EXPIRES_IN=7d

# Public API URL for frontend (Optional, default: /api)
# Use relative URL for same-origin API, or absolute URL for external API
# Examples: /api, https://api.example.com, https://api.vercel.app/api
NEXT_PUBLIC_API_URL=/api

# Public Application Name (Optional, default: Hostn)
NEXT_PUBLIC_APP_NAME=Hostn

# Public Application URL (REQUIRED for production)
# Used for links, redirects, and CORS configuration
# Examples: http://localhost:3000, https://hostn.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment Mode (Optional, for reference only)
# Values: development, staging, production
# NODE_ENV is automatically set by Next.js
