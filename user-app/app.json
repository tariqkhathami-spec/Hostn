{
  "expo": {
    "name": "Hostn",
    "slug": "hostn-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "hostn-app",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4B0082"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hostn.app",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true
      },
      "config": {
        "googleMapsApiKey": "AIzaSyD9mcyuKK3L2TUkZ7vep6xF_eUV5DzIDUw"
      }
    },
    "android": {
      "package": "com.hostn.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4B0082"
      },
      "permissions": [],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD9mcyuKK3L2TUkZ7vep6xF_eUV5DzIDUw"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c51f62f8-e674-402f-ba85-2fa0aa4b06e6"
      }
    },
    "owner": "tariqksa"
  }
}
