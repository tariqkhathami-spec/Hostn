# ============================================================================
# Hostn Platform — Environment Variables Reference
# ============================================================================
# Copy this file to .env in each service directory and fill in actual values.
# Never commit real secrets to version control.
# ============================================================================

# ── BACKEND (backend/.env) ───────────────────────────────────────────────────

# Required
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/hostn?retryWrites=true&w=majority
JWT_SECRET=your-secret-key-at-least-32-characters-long

# Server
PORT=5000
NODE_ENV=development

# CORS / Client
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Redis (optional — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Payment — Moyasar (optional — payments disabled if not set)
MOYASAR_SECRET_KEY=sk_test_...
MOYASAR_PUBLISHABLE_KEY=pk_test_...
MOYASAR_WEBHOOK_SECRET=whsec_...
MOYASAR_API_URL=https://api.moyasar.com/v1

# Cloud Storage (optional — falls back to local disk uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps (optional — geocoding disabled if not set)
GOOGLE_MAPS_SERVER_KEY=

# ── FRONTEND (frontend/.env.local) ──────────────────────────────────────────

NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Hostn
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── MOBILE (hostn-mobile/.env) ──────────────────────────────────────────────

EXPO_PUBLIC_API_URL=https://hostn-production.up.railway.app/api
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
